# App
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
PORT=4000
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://192.168.*:3000,http://10.*:3000,https://*.ngrok-free.app,https://*.ngrok.io

# Auth (JWT) — safe dev defaults; override in production
JWT_ACCESS_SECRET=dev-access-secret
JWT_REFRESH_SECRET=dev-refresh-secret
JWT_ACCESS_EXPIRES_SEC=900
JWT_REFRESH_EXPIRES_SEC=604800

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/listingpilot

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Storage (MinIO locally)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=listingpilot-assets
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# AI (Groq — free tier, get your key at https://console.groq.com/keys)
# A built-in key is used automatically if you leave these unset.
# To use your own key, uncomment and replace:
# GROQ_API_KEY=gsk_YOUR_KEY_HERE
OPENROUTER_BASE_URL=https://api.groq.com/openai/v1
OPENROUTER_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Qdrant (vector store for semantic dedup)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=listingpilot-products

# Worker
WORKER_PORT=4001
WORKER_CONCURRENCY=5

# Feature Flags
ENABLE_MOCK_CHANNELS=true
ENABLE_WALMART_CONNECTOR=false
ENABLE_ETSY_CONNECTOR=false
ENABLE_VOICE_INGESTION=false

# Frontend (apps/web)
# NEXT_PUBLIC_API_URL is auto-detected at runtime:
#   localhost → http://localhost:4000/api/v1 (direct)
#   external (ngrok, etc.) → same-origin /api/v1 (via Next.js proxy)
# Only set this if you need to override the auto-detection:
# NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
