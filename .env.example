# App
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Auth (JWT)
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRES_SEC=900
JWT_REFRESH_EXPIRES_SEC=604800

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/listingpilot

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Storage (MinIO locally)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=listingpilot-assets
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# AI
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Qdrant (vector store for semantic dedup)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=listingpilot-products

# Worker
WORKER_PORT=4001
WORKER_CONCURRENCY=5

# Feature Flags
ENABLE_MOCK_CHANNELS=true
ENABLE_WALMART_CONNECTOR=false
ENABLE_ETSY_CONNECTOR=false
ENABLE_VOICE_INGESTION=false

# Frontend (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
